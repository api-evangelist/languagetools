{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/languagetools/main/json-schema/language.json",
  "title": "Language",
  "description": "A supported language object returned by GET /languages",
  "type": "object",
  "required": ["name", "code", "longCode"],
  "properties": {
    "name": {
      "type": "string",
      "description": "A language name like 'French' or 'English (Australia)'."
    },
    "code": {
      "type": "string",
      "description": "A language code like 'en'."
    },
    "longCode": {
      "type": "string",
      "description": "A language code like 'en-US' or 'ca-ES-valencia'."
    }
  }
}
